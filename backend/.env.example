# Peptide Visual Lab - Backend Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Provider Flags
# =============================================================================

# Enable TANGO aggregation prediction (requires binary at TANGO_BINARY_PATH)
# Set to 1 for production with tools mounted, 0 for dev without TANGO binary
USE_TANGO=1

# Enable S4PRED secondary structure prediction (requires weights at S4PRED_MODEL_PATH)
USE_S4PRED=1

# =============================================================================
# Server Configuration
# =============================================================================

# Host and port for the FastAPI server
HOST=127.0.0.1
PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development

# CORS origins (comma-separated list)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# =============================================================================
# Tool Paths (optional)
# =============================================================================

# Path to TANGO binary (only needed if USE_TANGO=1)
# TANGO_BINARY_PATH=/path/to/tango/binary

# TANGO mode: 'simple' (direct binary) or 'docker' (container)
TANGO_MODE=simple

# Path to S4PRED model weights directory (only needed if USE_S4PRED=1)
# Must contain: weights_1.pt through weights_5.pt (~86MB each)
# S4PRED_MODEL_PATH=/path/to/s4pred/weights

# Runtime directories for tool outputs
# TANGO_RUNTIME_DIR=.run_cache/Tango
# S4PRED_RUNTIME_DIR=.run_cache/S4Pred

# =============================================================================
# Observability (optional)
# =============================================================================

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Sentry environment override
# SENTRY_ENVIRONMENT=development

# Enable Sentry debug mode
SENTRY_DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
