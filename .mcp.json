{
  "mcpServers": {
    "puppeteer": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/sse"
    },
    "refero": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-remote", "https://refero.design/mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.41"]
    }
  }
}
