# Example environment configuration for the UI
# Copy this file to .env.local and update the values as needed

# API Base URL - where the backend server is running
VITE_API_BASE_URL=http://127.0.0.1:8000

# Sentry DSN for the FRONTEND project (separate from backend Sentry project).
# Leave empty to disable Sentry on the frontend. PVL production uses Sentry
# org id 4510730454499328 with separate projects for frontend and backend.
# Get a fresh DSN from Sentry dashboard → Project Settings → Client Keys (DSN).
VITE_SENTRY_DSN=
