# UI Docker Ignore
# Prevents context bloat during Docker builds

# Dependencies
node_modules/
.pnpm-store/

# Build outputs (will be rebuilt in container)
dist/
build/
.next/

# Development files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# Test and coverage
coverage/
.nyc_output/

# Environment files
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Documentation
*.md
docs/
